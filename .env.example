# Default client contract: same-origin calls. Route constants include /api/v1.
VITE_API_BASE_URL=

# Dev proxy target for Vite. Use :8080 with the monorepo stack or :18080 with crm-infra isolated.
VITE_API_PROXY_TARGET=http://localhost:18080

# If you need to call the gateway directly from the browser, switch VITE_API_BASE_URL
# to the absolute URL and ensure KrakenD allows the frontend origin via CORS.
# VITE_API_BASE_URL=http://localhost:18080
